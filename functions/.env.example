# Runtime configuration (RedRun injects these per workspace/channel)
REDRUN_CHANNEL=beta
PORT=3000
PUBLIC_URL=https://redbook.redbtn.io
MONGODB_URI=mongodb://USER:PASS@mongo.internal:27017/redbook-beta?authSource=admin
MONGODB_DB=redbook-beta
AUTH_MONGODB_URI=mongodb://USER:PASS@mongo.internal:27017/redauth?authSource=admin
AUTH_MONGODB_DB=redauth

# Bootstrap access to the shared encrypted @redbtn/redsecrets store.
# JWT_SECRET, EMAIL_USER, and EMAIL_PASS are stored there, not here.
REDBOOK_SECRETS_ENCRYPTION_KEY=
REDSECRETS_DATABASE=redshared
